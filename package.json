{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev:ssr": "ng run portfolio:serve-ssr",
    "serve:ssr": "node dist/portfolio/proxy-server.js",
    "build:ssr": "ng build --configuration production && ng run portfolio:server && npm run post-build:ssr",
    "post-build:ssr": "cpx proxy-server.js dist/portfolio",
    "prerender": "ng run portfolio:prerender && npm run post-build:ssr"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~13.3.8",
    "@angular/cdk": "^13.3.7",
    "@angular/common": "~13.3.8",
    "@angular/compiler": "~13.3.8",
    "@angular/core": "~13.3.8",
    "@angular/forms": "~13.3.8",
    "@angular/material": "^13.3.7",
    "@angular/platform-browser": "~13.3.8",
    "@angular/platform-browser-dynamic": "~13.3.8",
    "@angular/platform-server": "~13.3.8",
    "@angular/router": "~13.3.8",
    "@fortawesome/angular-fontawesome": "^0.10.2",
    "@fortawesome/fontawesome-svg-core": "~6.1.1",
    "@fortawesome/free-brands-svg-icons": "^6.1.1",
    "@fortawesome/free-regular-svg-icons": "^6.1.1",
    "@fortawesome/free-solid-svg-icons": "^6.1.1",
    "@nguniversal/express-engine": "^13.1.1",
    "bootstrap": "^5.1.3",
    "cpx": "^1.5.0",
    "express": "^4.15.2",
    "rxjs": "~7.5.5",
    "swiper": "^8.1.5",
    "tslib": "^2.4.0",
    "zone.js": "~0.11.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~13.3.5",
    "@angular/cli": "~13.3.5",
    "@angular/compiler-cli": "~13.3.8",
    "@angular/localize": "^13.3.8",
    "@nguniversal/builders": "^13.1.1",
    "@types/express": "^4.17.0",
    "@types/jasmine": "~4.0.3",
    "@types/node": "^17.0.33",
    "jasmine-core": "~4.1.1",
    "karma": "~6.3.20",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.1",
    "karma-jasmine-html-reporter": "~1.7.0",
    "typescript": "~4.6.4"
